# ======================================
# 🌍 VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# ======================================

# URL do CDN (obrigatório para produção)
REACT_APP_CDN_URL=https://rpmon.intranet.policiamilitar.sp.gov.br

# URL da API
REACT_APP_API_URL=https://rpmonapi.intranet.policiamilitar.sp.gov.br

# Ambiente
NODE_ENV=production

# Desabilitar source maps em produção (reduz build)
GENERATE_SOURCEMAP=false

# Otimizações do Webpack
INLINE_RUNTIME_CHUNK=false
IMAGE_INLINE_SIZE_LIMIT=0

# ======================================
# 📝 INSTRUÇÕES:
# ======================================
# 1. Copie este arquivo para .env.production
# 2. Atualize REACT_APP_CDN_URL com sua URL real
# 3. Atualize REACT_APP_API_URL com URL da API
# 4. Build: npm run build
